<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>HyprWin.App</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>hyprwin.ico</ApplicationIcon>

    <!-- Assembly metadata — reduces AV false positives -->
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <InformationalVersion>1.0.0</InformationalVersion>
    <Company>HyprWin</Company>
    <Product>HyprWin</Product>
    <Authors>HyprWin Contributors</Authors>
    <Description>HyprWin — a Hyprland-inspired tiling window manager for Windows 11</Description>
    <Copyright>Copyright © 2025-2026 HyprWin Contributors</Copyright>

    <!-- Publish settings that reduce AV triggers -->
    <DebugType>embedded</DebugType>
    <PublishReadyToRun>true</PublishReadyToRun>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\HyprWin.Core\HyprWin.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="H.NotifyIcon.Wpf" Version="2.1.3" />
  </ItemGroup>
</Project>
