<Window x:Class="HyprWin.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HyprWin Settings"
        Width="620" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#89b4fa"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,14,0,6"/>
        </Style>
        <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#a6adc8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#45475a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="CheckStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#89b4fa"/>
            <Setter Property="Foreground" Value="#1e1e2e"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="20,8,20,0">
            <StackPanel>
                <!-- General -->
                <TextBlock Style="{StaticResource HeaderStyle}" Text="&#xE713;  General" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Terminal Command"/>
                    <TextBox x:Name="TerminalCmd" Grid.Column="1" Style="{StaticResource InputStyle}" Width="200" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Workspace Mode"/>
                    <ComboBox x:Name="WorkspaceMode" Grid.Column="1" Width="160" HorizontalAlignment="Left"
                              Background="#313244" Foreground="#cdd6f4" FontSize="13">
                        <ComboBoxItem Content="monitor_bound"/>
                        <ComboBoxItem Content="virtual"/>
                    </ComboBox>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Workspace Count"/>
                    <TextBox x:Name="WorkspaceCount" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Autostart with Windows"/>
                    <CheckBox x:Name="Autostart" Grid.Column="1" Style="{StaticResource CheckStyle}"/>
                </Grid>

                <!-- Layout -->
                <TextBlock Style="{StaticResource HeaderStyle}" Text="&#xE80A;  Layout"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Inner Gaps (px)"/>
                    <TextBox x:Name="GapsInner" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Outer Gaps (px)"/>
                    <TextBox x:Name="GapsOuter" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Border Size (px)"/>
                    <TextBox x:Name="BorderSize" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Corner Rounding (px)"/>
                    <TextBox x:Name="Rounding" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>

                <!-- Theme -->
                <TextBlock Style="{StaticResource HeaderStyle}" Text="&#xE790;  Theme"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Active Border Color"/>
                    <TextBox x:Name="BorderActive" Grid.Column="1" Style="{StaticResource InputStyle}" Width="120" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Inactive Border Color"/>
                    <TextBox x:Name="BorderInactive" Grid.Column="1" Style="{StaticResource InputStyle}" Width="120" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Top Bar Background"/>
                    <TextBox x:Name="TopBarBg" Grid.Column="1" Style="{StaticResource InputStyle}" Width="120" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Top Bar Foreground"/>
                    <TextBox x:Name="TopBarFg" Grid.Column="1" Style="{StaticResource InputStyle}" Width="120" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Top Bar Accent"/>
                    <TextBox x:Name="TopBarAccent" Grid.Column="1" Style="{StaticResource InputStyle}" Width="120" HorizontalAlignment="Left"/>
                </Grid>

                <!-- Top Bar -->
                <TextBlock Style="{StaticResource HeaderStyle}" Text="&#xE8A1;  Top Bar"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Enabled"/>
                    <CheckBox x:Name="TopBarEnabled" Grid.Column="1" Style="{StaticResource CheckStyle}"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Height (px)"/>
                    <TextBox x:Name="TopBarHeight" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Position"/>
                    <ComboBox x:Name="TopBarPosition" Grid.Column="1" Width="120" HorizontalAlignment="Left"
                              Background="#313244" Foreground="#cdd6f4" FontSize="13">
                        <ComboBoxItem Content="top"/>
                        <ComboBoxItem Content="bottom"/>
                    </ComboBox>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Font"/>
                    <TextBox x:Name="TopBarFont" Grid.Column="1" Style="{StaticResource InputStyle}" Width="200" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Font Size"/>
                    <TextBox x:Name="TopBarFontSize" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Right Modules"/>
                    <TextBox x:Name="TopBarModulesRight" Grid.Column="1" Style="{StaticResource InputStyle}" HorizontalAlignment="Stretch"
                             ToolTip="Comma-separated: tray, cpu, cpu_temp, gpu, gpu_temp, memory, volume, network, battery"/>
                </Grid>

                <!-- Animations -->
                <TextBlock Style="{StaticResource HeaderStyle}" Text="&#xE7B5;  Animations"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Preset"/>
                    <ComboBox x:Name="AnimPresetCombo" Grid.Column="1" Width="200" HorizontalAlignment="Left"
                              Background="#313244" Foreground="#cdd6f4" FontSize="13"
                              SelectionChanged="AnimPreset_SelectionChanged"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Enabled"/>
                    <CheckBox x:Name="AnimEnabled" Grid.Column="1" Style="{StaticResource CheckStyle}"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Open Duration (ms)"/>
                    <TextBox x:Name="AnimOpenDuration" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Close Duration (ms)"/>
                    <TextBox x:Name="AnimCloseDuration" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Move Duration (ms)"/>
                    <TextBox x:Name="AnimMoveDuration" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Easing"/>
                    <TextBox x:Name="AnimEasing" Grid.Column="1" Style="{StaticResource InputStyle}" Width="180" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Open Style"/>
                    <ComboBox x:Name="AnimOpenStyle" Grid.Column="1" Width="120" HorizontalAlignment="Left"
                              Background="#313244" Foreground="#cdd6f4" FontSize="13">
                        <ComboBoxItem Content="popin"/>
                        <ComboBoxItem Content="slide"/>
                        <ComboBoxItem Content="fade"/>
                    </ComboBox>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Popin Percent"/>
                    <TextBox x:Name="AnimPopinPercent" Grid.Column="1" Style="{StaticResource InputStyle}" Width="80" HorizontalAlignment="Left"/>
                </Grid>

                <!-- Gaming Mode -->
                <TextBlock Style="{StaticResource HeaderStyle}" Text="&#xE7FC;  Gaming Mode"/>
                <TextBlock Style="{StaticResource SubHeaderStyle}" Text="Reduces overhead when a fullscreen game is detected"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Auto-detect Games"/>
                    <CheckBox x:Name="GamingEnabled" Grid.Column="1" Style="{StaticResource CheckStyle}"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Suspend Animations"/>
                    <CheckBox x:Name="GamingSuspendAnim" Grid.Column="1" Style="{StaticResource CheckStyle}"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Suspend Border"/>
                    <CheckBox x:Name="GamingSuspendBorder" Grid.Column="1" Style="{StaticResource CheckStyle}"/>
                </Grid>

                <!-- Exclusions -->
                <TextBlock Style="{StaticResource HeaderStyle}" Text="&#xE711;  Exclusions"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Excluded Processes" ToolTip="Comma-separated process names without .exe"/>
                    <TextBox x:Name="ExcludedProcesses" Grid.Column="1" Style="{StaticResource InputStyle}" HorizontalAlignment="Stretch"
                             ToolTip="Comma-separated, e.g.: Taskmgr, Discord, vlc"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Popup Allowlist (Processes)" ToolTip="Optional: popup/dialog windows from these processes may be managed"/>
                    <TextBox x:Name="PopupAllowedProcesses" Grid.Column="1" Style="{StaticResource InputStyle}" HorizontalAlignment="Stretch"
                             ToolTip="Comma-separated, e.g.: photoshop, devenv"/>
                </Grid>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelStyle}" Text="Popup Allowlist (Classes)" ToolTip="Optional: popup/dialog windows with these classes may be managed"/>
                    <TextBox x:Name="PopupAllowedClasses" Grid.Column="1" Style="{StaticResource InputStyle}" HorizontalAlignment="Stretch"
                             ToolTip="Comma-separated class names"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,12,20,16">
            <Button Content="Open TOML" Style="{StaticResource BtnStyle}" Background="#45475a" Foreground="#cdd6f4"
                    Click="OpenToml_Click" Margin="0,0,8,0"/>
            <Button Content="Save" Style="{StaticResource BtnStyle}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
